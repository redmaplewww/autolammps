units metal
atom_style atomic
atom_modify map hash
boundary p p p

# Test Ti hcp energy with FIXED potential
lattice hcp 2.95
region box block 0 3 0 3 0 2
create_box 1 box
create_atoms 1 box
mass 1 47.867

pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003-fixed.eam.alloy Ti

thermo 1
minimize 1e-10 1e-10 1000 10000
run 0
print ""
print "=== Ti hcp energy with FIXED potential ==="
print "Expected: -4.843 eV/atom"
print "Computed: $(pe)/72"
