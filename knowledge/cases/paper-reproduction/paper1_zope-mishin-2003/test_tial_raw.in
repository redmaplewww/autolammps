units metal
atom_style atomic
boundary p p p

# TiAl L1_0 - check energy at EXACT paper lattice constants (no minimization)
# Paper: a_0 = 3.998 A, c/a = 1.047, E_0 = 4.509 eV/atom

variable a0 equal 3.998
variable c0 equal 3.998*1.047

# Create a 2x2x2 supercell
lattice custom ${a0} a1 1.0 0.0 0.0 a2 0.0 1.0 0.0 a3 0.0 0.0 ${c0} &
  basis 0.0 0.0 0.0 basis 0.5 0.5 0.0 basis 0.5 0.0 0.5 basis 0.0 0.5 0.5
region box block 0 2 0 2 0 2 units lattice
create_box 2 box
create_atoms 1 box basis 1 2 basis 2 2 basis 3 1 basis 4 1
mass 1 47.867
mass 2 26.982
pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003.eam.alloy Ti Al
neighbor 2.0 bin
neigh_modify delay 5 every 1

# NO minimization - just compute energy
run 0 post no

variable Etot equal pe
variable Eper equal pe/count(all)
variable Eper2 equal Etot/32
variable ca_eq equal lz/lx

print ""
print "=============================================="
print "TiAl L1_0 at paper's lattice constants (32 atoms)"
print "a = ${a0}, c = ${c0}, c/a = ${ca_eq}"
print "Total PE = ${Etot} eV"
print "Per atom = ${Eper2} eV"
print "=============================================="

# Compare with Al fcc and Ti hcp references
# From our calculations:
# Al fcc (a=4.05): E = -3.36 eV/atom
# Ti hcp (a=2.95): E = -4.843 eV/atom
# Expected formation: -0.404 eV/atom
# Expected TiAl energy: -0.404 + 0.5*(-4.843) + 0.5*(-3.36) = -4.506 eV/atom

variable E_Al_ref equal -3.36
variable E_Ti_ref equal -4.843
variable E_TiAl_expected equal -0.404 + 0.5*${E_Ti_ref} + 0.5*${E_Al_ref}
variable E_form_computed equal ${Eper2} - 0.5*${E_Ti_ref} - 0.5*${E_Al_ref}

print ""
print "Expected TiAl energy: ${E_TiAl_expected} eV/atom"
print "Expected formation energy: -0.404 eV/atom"
print "Computed formation energy: ${E_form_computed} eV/atom"
