units metal
atom_style atomic
boundary p p p

# TiAl L1_0: a=3.998, c=4.187
# The lattice custom with a1=(a,0,0), a2=(0,a,0), a3=(0,0,c)
# uses an ORTHORHOMBIC cell with 4 atoms per cell.
# Basis atoms for orthorhombic L1_0:
# Al at (0,0,0), Al at (0.5a,0.5a,0), Ti at (0.5a,0,0.5c), Ti at (0,0.5a,0.5c)

lattice custom 3.998 a1 1.0 0.0 0.0 a2 0.0 1.0 0.0 a3 0.0 0.0 4.187 &
  basis 0.0 0.0 0.0 basis 0.5 0.5 0.0 basis 0.5 0.0 0.5 basis 0.0 0.5 0.5

region box block 0 4 0 4 0 4 units lattice
create_box 2 box

# Map basis to atom types:
# basis 1: (0,0,0) -> Al (type 2)
# basis 2: (0.5a,0.5a,0) -> Al (type 2)
# basis 3: (0.5a,0,0.5c) -> Ti (type 1)
# basis 4: (0,0.5a,0.5c) -> Ti (type 1)
create_atoms 1 box basis 1 2 basis 2 2 basis 3 1 basis 4 1

mass 1 47.867  # Ti
mass 2 26.982  # Al

pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003.eam.alloy Ti Al

neighbor 2.0 bin
neigh_modify delay 5 every 1

# Relax box
fix 1 all box/relax x 0.0 y 0.0 z 0.0
minimize 1e-10 1e-10 10000 100000
unfix 1

variable natoms equal count(all)
variable Etot equal pe
variable Eper equal pe/count(all)
variable a_eq equal lx/4
variable c_eq equal lz/4
variable ca_eq equal lz/lx

group gTi type 1
group gAl type 2
variable nTi equal count(gTi)
variable nAl equal count(gAl)

print ""
print "=============================================="
print "TiAl L1_0 (CORRECTED basis, 256 atoms)"
print "Total atoms = ${natoms}, Ti=${nTi}, Al=${nAl}"
print "a=${a_eq}, c=${c_eq}, c/a=${ca_eq}"
print "Energy = ${Eper} eV/atom"
print "Expected: -4.509 eV/atom"
print "Formation: -0.404 eV/atom"
print "=============================================="
