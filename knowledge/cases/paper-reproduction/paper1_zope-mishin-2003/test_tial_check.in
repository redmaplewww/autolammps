units metal
atom_style atomic
boundary p p p

# TiAl L1_0: Check atom positions and nearest neighbors
lattice custom 3.998 a1 1.0 0.0 0.0 a2 0.0 1.0 0.0 a3 0.0 0.0 4.187 &
  basis 0.0 0.0 0.0 basis 0.5 0.5 0.0 basis 0.5 0.0 0.5 basis 0.0 0.5 0.5
region box block 0 2 0 2 0 2 units lattice
create_box 2 box
create_atoms 1 box basis 1 2 basis 2 2 basis 3 1 basis 4 1
mass 1 47.867
mass 2 26.982
pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003.eam.alloy Ti Al

# Dump atom positions
dump 1 all custom 1 dump.pos id type x y z
run 0

# Compute nearest neighbor distances
compute 1 all pair/local phi
compute 2 all compute pair/local dist

# Also compute per-atom energy
compute peA all pe/atom
dump 2 all custom 1 dump.energy id type c_peA x y z
run 0
