units metal
atom_style atomic
boundary p p p

# TiAl L1_0 with energy decomposition
lattice custom 3.998 a1 1.0 0.0 0.0 a2 0.0 1.0 0.0 a3 0.0 0.0 4.187 &
  basis 0.0 0.0 0.0 basis 0.5 0.5 0.0 basis 0.5 0.0 0.5 basis 0.0 0.5 0.5
region box block 0 4 0 4 0 4 units lattice
create_box 2 box
create_atoms 1 box basis 1 2 basis 2 2 basis 3 1 basis 4 1
mass 1 47.867
mass 2 26.982
pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003.eam.alloy Ti Al
neighbor 2.0 bin
neigh_modify delay 5 every 1

# Compute per-atom energies
compute peA all pe/atom

# Group by type
group gTi type 1
group gAl type 2

# Compute average per-atom energy for each type
compute peTi gTi reduce ave c_peA
compute peAl gAl reduce ave c_peA

# Print box and atom info
variable natoms equal count(all)
variable nTi equal count(gTi)
variable nAl equal count(gAl)
print ""
print "Total atoms = ${natoms}, Ti=${nTi}, Al=${nAl}"
print "Box: lx=$(lx), ly=$(ly), lz=$(lz)"

# Run without minimization to see initial energy
run 0 post no

variable Etot equal pe
variable Eper equal pe/count(all)
variable Epair equal pe/count(all)  # This is total (pair + embed)

print ""
print "TiAl L1_0 initial energy (no minimization):"
print "Total PE = ${Etot} eV"
print "Per atom = ${Eper} eV/atom"
print "Expected: -4.509 eV/atom"

# Get per-type energies
variable ETi equal c_peTi
variable EAl equal c_peAl
print "Ti atoms average: ${ETi} eV/atom"
print "Al atoms average: ${EAl} eV/atom"

# Now minimize
minimize 1e-10 1e-10 10000 100000

variable Etot2 equal pe
variable Eper2 equal pe/count(all)
print ""
print "After minimization:"
print "Total PE = ${Etot2} eV"
print "Per atom = ${Eper2} eV/atom"

variable ETi2 equal c_peTi
variable EAl2 equal c_peAl
print "Ti atoms average: ${ETi2} eV/atom"
print "Al atoms average: ${EAl2} eV/atom"
