# Compute pure Al fcc energy
units metal
atom_style atomic
boundary p p p
variable aAl equal 4.05
region reg block 0 16.2 0 16.2 0 16.2 units box
create_box 1 reg
lattice fcc ${aAl}
create_atoms 1 region reg
mass 1 26.982
pair_style eam/alloy
pair_coeff * * Zope-Ti-Al-2003.eam.alloy Al
neighbor 2.0 bin
minimize 1e-12 1e-12 10000 10000
run 0
variable E_Al equal $(pe/atoms)
print "=== Al fcc PE/atom = ${E_Al} ==="
