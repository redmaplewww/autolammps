# Paper 3: Al0.1CrCoFeNi HEA melt-quench workflow
# Sharma 2016 style: melt -> quench -> equilibrate

units metal
atom_style atomic
boundary p p p

variable alat equal 3.59
lattice fcc ${alat}
region box block 0 5 0 5 0 5 units lattice
create_box 5 box
create_atoms 5 box

# type map: 1 Al, 2 Cr, 3 Co, 4 Fe, 5 Ni
mass 1 26.9815
mass 2 51.9961
mass 3 58.9332
mass 4 55.8450
mass 5 58.6934

set type 5 type/fraction 1 0.10 12345
set type 5 type/fraction 2 0.25 22345
set type 5 type/fraction 3 0.333333 32345
set type 5 type/fraction 4 0.50 42345

pair_style meam
pair_coeff * * "F:/opencode/claude-code-main/claude-code-main/knowledge/potentials/meam/FeMnNiTiCuCrCoAl_library.meam" Al Co Cu Cr Fe Mn Ni Ti "F:/opencode/claude-code-main/claude-code-main/knowledge/potentials/meam/FeMnNiTiCuCrCoAl.meam" Al Cr Co Fe Ni

neighbor 2.0 bin
neigh_modify delay 5 every 1

group Al type 1
group Cr type 2
group Co type 3
group Fe type 4
group Ni type 5
variable nAl equal count(Al)
variable nCr equal count(Cr)
variable nCo equal count(Co)
variable nFe equal count(Fe)
variable nNi equal count(Ni)

print "Initial composition: Al=${nAl} Cr=${nCr} Co=${nCo} Fe=${nFe} Ni=${nNi} total=$(atoms)"

velocity all create 300 55555 mom yes rot no dist gaussian
timestep 0.001
compute t all temp
compute p all pressure t
thermo 200
thermo_style custom step temp pe press vol

# melt
fix melt all npt temp 2000 2000 0.1 iso 0 0 1
run 3000
unfix melt

# quench
fix quench all npt temp 2000 300 0.1 iso 0 0 1
run 6000
unfix quench

# equilibrate solid
fix eq all npt temp 300 300 0.1 iso 0 0 1
run 2000
unfix eq

variable mtot equal ${nAl}*26.9815+${nCr}*51.9961+${nCo}*58.9332+${nFe}*55.8450+${nNi}*58.6934
variable rho equal ${mtot}/vol*1.66054
print "PAPER3_RESULT nAl=${nAl} nCr=${nCr} nCo=${nCo} nFe=${nFe} nNi=${nNi} pe=$(pe) vol=$(vol) rho=${rho}"
